<!DOCTYPE html>
<html>
<head>
    <title>Profile</title>

<style>
body {
    margin: 0;
    font-family: 'Segoe UI', sans-serif;
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: white;
}

/* NAVBAR */
.navbar {
    display: flex;
    justify-content: space-between;
    padding: 15px 20px;
    background: rgba(0,0,0,0.3);
}

.navbar a {
    color: white;
    text-decoration: none;
    margin-left: 15px;
}

/* CONTAINER */
.container {
    max-width: 900px;
    margin: 40px auto;
    display: flex;
    gap: 20px;
}

/* PROFILE CARD */
.profile-card {
    flex: 1;
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(12px);
    padding: 20px;
    border-radius: 15px;
    text-align: center;
}

.avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    margin-bottom: 10px;
}

/* EDIT FORM */
.edit-card {
    flex: 2;
    background: rgba(0,0,0,0.3);
    padding: 20px;
    border-radius: 15px;
}

input {
    width: 100%;
    padding: 10px;
    margin: 10px 0;
    border-radius: 8px;
    border: none;
}

button {
    padding: 10px 15px;
    background: #00c9a7;
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
}

button:hover {
    background: #00a78e;
}

.profile-card p {
    margin: 8px 0;
    font-size: 15px;
}
</style>
</head>

<body>

<!-- NAVBAR -->
<div class="navbar">
    <h2>👤 Profile</h2>
    <div>
        <a href="/tasks">Dashboard</a>
        <a href="/logout">Logout</a>
    </div>
</div>

<div class="container">

    <!-- PROFILE INFO -->
    <div class="profile-card">
        <img 
    src="<%= user.profileImage ? user.profileImage : 'https://ui-avatars.com/api/?name=' + user.username %>" 
    class="avatar"
>

        <h3><%= user.username %></h3>
        <p><%= user.email %></p>
    </div>

    <!-- EDIT PROFILE -->
    <div class="edit-card">
        <h3>✏️ Edit Profile</h3>
        

        <form action="/profile/update" method="POST" enctype="multipart/form-data">
            <input type="text" name="username" value="<%= user.username %>" required>
            <input type="email" name="email" value="<%= user.email %>" required>
            <input type="file" name="profileImage">
            <input type="password" name="password" placeholder="New Password (optional)">

            <button type="submit">Update Profile</button>
            
        </form>
    </div>
<div class="profile-card">
    <h3>📊 My Stats</h3>
    <p>📁 Total Tasks: <%= stats.total %></p>
    <p>✅ Completed: <%= stats.completed %></p>
    <p>🟡 Pending: <%= stats.pending %></p>
    <p>🔵 In Progress: <%= stats.inProgress %></p>
</div>
</div>

</body>
</html>