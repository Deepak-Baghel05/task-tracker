<!DOCTYPE html>
<html>
<head>
    <title>Dashboard</title>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
body {
    font-family: 'Segoe UI', sans-serif;
    background: linear-gradient(135deg, #667eea, #764ba2);
    margin: 0;
    padding: 20px;
    color: #fff;
}

.navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(0,0,0,0.3);
    padding: 15px 20px;
    border-radius: 12px;
    margin-bottom: 20px;
}

.navbar a {
    color: white;
    margin-left: 15px;
    text-decoration: none;
}

.logout {
    background: #ff4d4d;
    padding: 6px 12px;
    border-radius: 6px;
}

/* 🔥 TOP SECTION */
.top-section {
    display: flex;
    gap: 20px;
    margin-bottom: 20px;
}

.performance, .chart-box {
    flex: 1;
    background: rgba(0,0,0,0.3);
    padding: 15px;
    border-radius: 15px;
}

/* BOARD */
.board {
    display: flex;
    gap: 20px;
}

.column {
    flex: 1;
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
    border-radius: 15px;
    padding: 15px;
    min-height: 400px;
}

.card {
    background: rgba(255,255,255,0.15);
    padding: 15px;
    border-radius: 12px;
    margin-bottom: 15px;
    transition: 0.3s;
}

.card:hover {
    transform: translateY(-5px);
}

select {
    padding: 8px 10px;
    border: none;
    border-radius: 6px;
    background: rgba(255,255,255,0.9);
    color: #333;
    font-size: 14px;
    cursor: pointer;
    margin-right: 8px;
}

select:focus {
    outline: 2px solid #00c9a7;
}

.form-group {
    display: flex;
    gap: 8px;
    margin-top: 10px;
    align-items: center;
}

button {
    border: none;
    padding: 8px 12px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
}

.update-btn {
    background: #00c9a7;
    color: white;
}

.update-btn:hover {
    background: #00b898;
}

.delete-btn {
    background: #ff4d4d;
    color: white;
}

.delete-btn:hover {
    background: #ff3333;
}
.create-task-box {
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(15px);
    padding: 25px;
    border-radius: 20px;
    margin-bottom: 25px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.3);
}

.create-task-box h2 {
    margin-bottom: 20px;
    font-weight: 600;
}

.task-form {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
}

/* FLOATING INPUT STYLE */
.input-group {
    position: relative;
    flex: 1;
    min-width: 200px;
}

.input-group input,
.input-group select {
    width: 100%;
    padding: 12px;
    border: none;
    border-radius: 10px;
    outline: none;
    background: rgba(255,255,255,0.2);
    color: white;
    font-size: 14px;
}

/* Labels */
.input-group label {
    position: absolute;
    top: 50%;
    left: 12px;
    transform: translateY(-50%);
    color: #ddd;
    font-size: 13px;
    pointer-events: none;
    transition: 0.3s;
}

/* Animation */
.input-group input:focus + label,
.input-group input:valid + label,
.input-group select:focus + label,
.input-group select:valid + label {
    top: -8px;
    left: 10px;
    font-size: 11px;
    color: #00ffd5;
}

/* BUTTON */
.create-btn {
    padding: 12px 20px;
    background: linear-gradient(45deg, #00c9a7, #00f2fe);
    border: none;
    border-radius: 10px;
    color: white;
    font-weight: bold;
    cursor: pointer;
    transition: 0.3s;
}

.create-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 0 15px rgba(0,255,200,0.6);
}
</style>
</head>

<body>

<!-- NAVBAR -->
<nav class="navbar">
    <h2>🚀 TaskManager</h2>
    <div>
        <a href="/tasks">Dashboard</a>
        <a href="/profile">Profile</a>
        <a href="/logout" class="logout">Logout</a>
    </div>
</nav>

<!-- 🔥 TOP SECTION -->
<div class="top-section">

    <!-- TEAM PERFORMANCE -->
    <div class="performance">
        <h3>👥 Team Performance</h3>
        <% for(let user in userStats) { %>
            <p>👤 <b><%= user %></b> → <%= userStats[user] %> completed</p>
        <% } %>
    </div>

    <!-- 📊 CHART -->
    <div class="chart-box">
        <h3>📊 Task Overview</h3>
        <canvas id="taskChart"></canvas>
    </div>

</div>


<div class="create-task-box">
    <h2>✨ Create New Task</h2>

    <form action="/tasks" method="POST" class="task-form">

        <div class="input-group">
            <input type="text" name="title" required>
            <label>Task Title</label>
        </div>

        <div class="input-group">
            <input type="text" name="description" required>
            <label>Description</label>
        </div>

        <div class="input-group">
            <select name="assignedTo" required>
                <option value="" disabled selected></option>
                <% users.forEach(user => { %>
                    <option value="<%= user._id %>"><%= user.username %></option>
                <% }) %>
            </select>
            <label>Assign To</label>
        </div>

        <button class="create-btn">🚀 Create Task</button>

    </form>
</div>


<!-- BOARD -->
<div class="board">

    <!-- TO DO -->
    <div class="column">
        <h3>🟡 To Do</h3>
        <% tasks.filter(t => t.status === 'pending').forEach(t => { %>
            <div class="card">
                <h4><%= t.title %></h4>
                <p><%= t.description %></p>
                <p>👤 <%= t.assignedTo?.username %></p>

                <div class="form-group">
                    <form action="/tasks/<%= t._id %>" method="POST" style="display: flex; gap: 8px;">
                        <select name="status" required>
                            <option value="pending" selected>pending</option>
                            <option value="in-progress">in-progress</option>
                            <option value="completed">completed</option>
                        </select>
                        <button type="submit" class="update-btn">Update</button>
                    </form>

                    <form action="/tasks/<%= t._id %>?_method=DELETE" method="POST" style="display: inline;">
                        <button type="submit" class="delete-btn">🗑 Delete</button>
                    </form>
                </div>
            </div>
        <% }) %>
    </div>

    <!-- IN PROGRESS -->
    <div class="column">
        <h3>🔵 In Progress</h3>
        <% tasks.filter(t => t.status === 'in-progress').forEach(t => { %>
            <div class="card">
                <h4><%= t.title %></h4>
                <p><%= t.description %></p>
                <p>👤 <%= t.assignedTo?.username %></p>

                <div class="form-group">
                    <form action="/tasks/<%= t._id %>" method="POST" style="display: flex; gap: 8px;">
                        <select name="status" required>
                            <option value="pending">pending</option>
                            <option value="in-progress" selected>in-progress</option>
                            <option value="completed">completed</option>
                        </select>
                        <button type="submit" class="update-btn">Update</button>
                    </form>

                    <form action="/tasks/<%= t._id %>?_method=DELETE" method="POST" style="display: inline;">
                        <button type="submit" class="delete-btn">🗑 Delete</button>
                    </form>
                </div>
            </div>
        <% }) %>
    </div>

    <!-- COMPLETED -->
    <div class="column">
        <h3>🟢 Completed</h3>
        <% tasks.filter(t => t.status === 'completed').forEach(t => { %>
            <div class="card">
                <h4><%= t.title %></h4>
                <p><%= t.description %></p>
                <p>👤 <%= t.assignedTo?.username %></p>

                <div class="form-group">
                    <form action="/tasks/<%= t._id %>" method="POST" style="display: flex; gap: 8px;">
                        <select name="status" required>
                            <option value="pending">pending</option>
                            <option value="in-progress">in-progress</option>
                            <option value="completed" selected>completed</option>
                        </select>
                        <button type="submit" class="update-btn">Update</button>
                    </form>
                    <!--<form action="/tasks/<%= t._id %>?_method=DELETE" method="POST" style="display: inline;">-->
                    <form action="/tasks/<%= t._id %>?_method=DELETE" method="POST" style="display: inline;">
                        <button type="submit" class="delete-btn">🗑 Delete</button>
                    </form>
                </div>
            </div>
        <% }) %>
    </div>

</div>

<!-- 📊 CHART SCRIPT -->
<script>
/*const pendingCount = <%= pendingCount %>;
const progressCount = <%= progressCount %>;
const completedCount = <%= completedCount %>;*/
const ctx = document.getElementById('taskChart');

new Chart(ctx, {
    type: 'doughnut',
    data: {
        labels: ['Pending', 'In Progress', 'Completed'],
        datasets: [{
            label: 'Tasks',
            data: [
    pendingCount,
    progressCount,
    completedCount
],
            backgroundColor: [
                '#ffc107',
                '#2196f3',
                '#4caf50'
            ],
            borderColor: [
                '#ff9800',
                '#1976d2',
                '#388e3c'
            ],
            borderWidth: 2
        }]
    },
    options: {
        responsive: true,
        plugins: {
            legend: {
                labels: {
                    color: 'white',
                    padding: 15,
                    font: {
                        size: 14
                    }
                }
            }
        }
    }
});
</script>

</body>
</html>